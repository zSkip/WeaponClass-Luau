function DarkHeart.RAbility(PassThrough) -- Heal Bloxy Cola, 3 healing burst for 10 hp each burst
	
	local Player = PassThrough['Player']
	
	local Replica = Data:ReturnTempReplica(Player)
	local HereData = Data:ReturnTempData(Player)

	if HereData.CanR <= workspace:GetServerTimeNow() and Player.Character.Humanoid.Health > 0 then

		local EffectData = Data:ReturnEffectReplica(Player)

		local Tool = Player.Character:FindFirstChild(HereData.SelectedClass)

		Replica:Set({'CanR'},workspace:GetServerTimeNow() + 15) -- CoolDown

		Replica:Set({'UsingR'}, true) -- State of attack
		
		EffectData:Set({''},{

			EffectName = 'DarkHearR' ;
			PassThrough = {Target = Tool.Handle} ;
			
		})

		Replica:Set({'Damage'},HereData.Damage + 20)

		task.spawn(function()

			task.wait(15)

			Replica:Set({'UsingR'},false)
			Replica:Set({'Damage'},HereData.Damage - 20)

		end)


	end
	
end

