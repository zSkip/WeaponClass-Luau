function WeaponMaker.NewWeapon(NewWeaponParam:NewWeaponParam)

	local self = setmetatable({
		
		Identifier = NewWeaponParam.WeaponIdentifer ;
		
		WeaponModel = NewWeaponParam.WeaponModel ;
		
		KeyBinds = {} ;
		
		MouseBinds = {} ;
		
		CreatedIndex = Indexer.New({Remote = IndexerPath.Weapons ; Identifier = NewWeaponParam.WeaponIdentifer}) ;
		
		IndexReference = Indexer ;
	
	},WeaponClassMeta) ;
	
	WeaponMaker.CreatedWeapons[NewWeaponParam.WeaponIdentifer] = self ;

	return self ;
	
end ;

function WeaponClass:CreateAbility(BindClassData:AbilityBindClassData) -- general for abilites 
	
	if BindClassData.Input.EnumType == Enum.KeyCode then
		
		self.KeyBinds[BindClassData.Input.Name] = setmetatable({ 

			Input = BindClassData.Input ;

			Damage = BindClassData.Damage ;

			HitboxRange = BindClassData.HitboxRange ;

			Animation = BindClassData.Animation ;
			AnimationFrames = 0 ;

			AttackSpeed = BindClassData.AttackSpeed ;
	
			CoolDown = os.time() ;
			IsActive = false ;

			Identifier = self.Identifier ;
			
			BoundFunctions = {} ;

		},BindClassMeta) ;
		
		return self.KeyBinds[BindClassData.Input.Name]

	elseif BindClassData.Input.EnumType == Enum.UserInputType then
		
		self.MouseBinds[BindClassData.Input.Name] = setmetatable({ 

			Input = BindClassData.Input ;

			Damage = BindClassData.Damage ;

			HitboxRange = BindClassData.HitboxRange ;

			Animation = BindClassData.Animation ;
			AnimationFrames = 0 ;

			AttackSpeed = BindClassData.AttackSpeed ;
			
			CoolDown = os.time() ;
			IsActive = false ; 

			Identifier = self.Identifier ;
			
			BoundFunctions = {} ;

		},BindClassMeta) ;
		
		return self.MouseBinds[BindClassData.Input.Name]
		
	end ;
	
end ;

function WeaponClass:CreateGeneralBind(BindClassData:GeneralBindClassData) -- general for keybinds
	
	if BindClassData.Input.EnumType == Enum.KeyCode then

		self.KeyBinds[BindClassData.Input.Name] = setmetatable({ 

			Input = BindClassData.Input ;

			Identifier = self.Identifier ;
			
			BoundFunctions = {} ;
			
			IsActive = false ;

		},BindClassMeta) ;
		
		for Index,Value in BindClassData.AdditionalDictionary do

			self.KeyBinds[BindClassData.Input.Name][Index] = Value

		end

		return self.KeyBinds[BindClassData.Input.Name]

	elseif BindClassData.Input.EnumType == Enum.UserInputType then

		self.MouseBinds[BindClassData.Input.Name] = setmetatable({ 

			Input = BindClassData.Input ;

			Identifier = self.Identifier  ;
			
			BoundFunctions = {} ; 
			
			IsActive = false ;

		},BindClassMeta) ;
		
		for Index,Value in BindClassData.AdditionalDictionary do
			
			self.KeyBinds[BindClassData.Input.Name][Index] = Value
			
		end

		return self.MouseBinds[BindClassData.Input.Name]

	end ;

	
end

function BindClass:BindFunction(PassedFunction)
	
	local self : BindFunctionBasic = self
	
	table.insert(self.BoundFunctions,PassedFunction)

end ;

return WeaponMaker ;
