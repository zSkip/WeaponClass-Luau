local Indexer = require(game.ReplicatedStorage.IndexerV2) ;
local IndexerPath = game.ReplicatedStorage.IndexerV2 ;

type NewWeaponParam = {
	
	WeaponModel : Model ;
	
	WeaponIdentifer : string ;
	
}

type DamageType = {
	
	DamageNumber : number ; 
	
	DamageType : "Physical" | "Magical" | "True"
	
}

type AbilityBindClassData = {
	
	Input : Enum.KeyCode | Enum.UserInputType ;
	
	Damage : number | DamageType ;
	
	HitboxRange : number ;
	
	Animation : number ;
	
	AttackSpeed : number ;
	
}

type GeneralBindClassData = {
	
	Input : Enum.KeyCode | Enum.UserInputType ;
	
	AdditionalDictionary : {any} ; 
	
}

type BindFunctionBasic = {
	
	Input : Enum.KeyCode | Enum.UserInputType ;
	
	Identifier : string ; 
	
	BoundFunctions : {} ;
	
}

